{
  "$schema_version": 1,
  "$comment": "Each finding's detect.probe is dispatched via reflection by Audit.Engine.ps1. found=true means the issue is present. cost.type marks honesty: measured (real RSS now), estimated (cited average), qualitative (on/off).",
  "findings": [

    {
      "id": "privacy-telemetry-allowtelemetry",
      "category": "privacy",
      "severity": "critical",
      "title": "Telemetry above Security level",
      "description": "Windows is sending diagnostic data above the minimum 'Security' level. Includes app usage, browsing history (Edge), and inking/typing data on Enhanced or Full.",
      "detect": {
        "probe": "Test-RegistryValueGreaterThan",
        "args": {
          "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DataCollection",
          "name": "AllowTelemetry",
          "threshold": 0,
          "treat_missing_as": 1
        }
      },
      "cost": { "type": "qualitative" },
      "remediation": {
        "description": "Set AllowTelemetry to 0 (Security)",
        "type": "module",
        "target": "modules/security/PrivacySexy.ps1",
        "requires_reboot": false
      }
    },

    {
      "id": "privacy-diagtrack-running",
      "category": "privacy",
      "severity": "critical",
      "title": "DiagTrack (Connected User Experiences and Telemetry) running",
      "description": "DiagTrack is the service that uploads diagnostic data to Microsoft. Disabling it stops the upload regardless of AllowTelemetry level.",
      "detect": {
        "probe": "Test-ServiceRunning",
        "args": { "name": "DiagTrack" }
      },
      "cost": { "type": "estimated", "ram_mb": 30 },
      "remediation": {
        "description": "Stop and disable DiagTrack",
        "type": "inline",
        "target": "Stop-Service DiagTrack -Force; Set-Service DiagTrack -StartupType Disabled",
        "requires_reboot": false
      }
    },

    {
      "id": "privacy-copilot-package",
      "category": "privacy",
      "severity": "warning",
      "title": "Copilot package installed",
      "description": "Microsoft Copilot UWP package is installed and may run in the background.",
      "detect": {
        "probe": "Test-AppxPackageInstalled",
        "args": { "pattern": "Microsoft.Copilot*" }
      },
      "cost": { "type": "estimated", "ram_mb": 180 },
      "remediation": {
        "description": "Remove Copilot via RemoveWindowsAI tool",
        "type": "module",
        "target": "modules/security/RemoveWindowsAI.ps1",
        "requires_reboot": false
      }
    },

    {
      "id": "privacy-recall-package",
      "category": "privacy",
      "severity": "critical",
      "title": "Recall package installed",
      "description": "Windows Recall captures periodic screenshots of your activity. Privacy and storage concern.",
      "detect": {
        "probe": "Test-AppxPackageInstalled",
        "args": { "pattern": "*Recall*" }
      },
      "cost": { "type": "estimated", "disk_mb": 1500 },
      "remediation": {
        "description": "Remove Recall via RemoveWindowsAI tool",
        "type": "module",
        "target": "modules/security/RemoveWindowsAI.ps1",
        "requires_reboot": false
      }
    },

    {
      "id": "privacy-onedrive-autostart",
      "category": "privacy",
      "severity": "warning",
      "title": "OneDrive auto-start enabled",
      "description": "OneDrive runs at login and consumes RAM/CPU even when not actively syncing.",
      "detect": {
        "probe": "Test-RegistryValueExists",
        "args": {
          "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run",
          "name": "OneDrive"
        }
      },
      "cost": { "type": "estimated", "ram_mb": 120 },
      "remediation": {
        "description": "Remove OneDrive Run entry",
        "type": "registry",
        "target": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run\\OneDrive=DELETE",
        "requires_reboot": false
      }
    },

    {
      "id": "privacy-advertising-id",
      "category": "privacy",
      "severity": "warning",
      "title": "Advertising ID enabled",
      "description": "Windows assigns a per-user advertising ID used by apps for cross-app tracking.",
      "detect": {
        "probe": "Test-RegistryValueNotEquals",
        "args": {
          "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\AdvertisingInfo",
          "name": "Enabled",
          "expected": 0,
          "treat_missing_as": 1
        }
      },
      "cost": { "type": "qualitative" },
      "remediation": {
        "description": "Set AdvertisingInfo Enabled=0",
        "type": "module",
        "target": "modules/security/PrivacySexy.ps1",
        "requires_reboot": false
      }
    },

    {
      "id": "privacy-activity-history",
      "category": "privacy",
      "severity": "warning",
      "title": "Activity history sync enabled",
      "description": "Windows uploads activity history to Microsoft for Timeline cross-device sync.",
      "detect": {
        "probe": "Test-RegistryValueNotEquals",
        "args": {
          "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\System",
          "name": "UploadUserActivities",
          "expected": 0,
          "treat_missing_as": 1
        }
      },
      "cost": { "type": "qualitative" },
      "remediation": {
        "description": "Set UploadUserActivities=0",
        "type": "module",
        "target": "modules/security/PrivacySexy.ps1",
